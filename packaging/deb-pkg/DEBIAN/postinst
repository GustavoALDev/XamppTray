#!/bin/bash
set -e

APP_DIR="/usr/share/xampp-tray"
SUDOERS_FILE="/etc/sudoers.d/xampp-tray"
LOG_FILE="/var/log/xampp-tray-install.log"

# Redireciona stdout e stderr para o log e para o terminal
exec > >(tee -a "$LOG_FILE") 2>&1

echo "=== Instalacao iniciada: $(date) ==="

# Trap para capturar erros e informar o usuario
trap 'echo "[ERRO] Falha na linha $LINENO. Verifique o log em $LOG_FILE para detalhes." >&2' ERR

# Check if XAMPP is installed
if [ ! -f "/opt/lampp/lampp" ]; then
    echo "XAMPP nao encontrado em /opt/lampp. Iniciando instalacao automatica..."
    
    XAMPP_VER="8.2.12-0"
    XAMPP_URL="https://downloads.sourceforge.net/project/xampp/XAMPP%20Linux/8.2.12/xampp-linux-x64-8.2.12-0-installer.run"
    INSTALLER="/tmp/xampp-installer.run"

    echo "Baixando XAMPP ${XAMPP_VER} do SourceForge..."
    # Usamos -L para seguir redirecionamentos do SourceForge
    if wget -L -O "$INSTALLER" "$XAMPP_URL"; then
        chmod +x "$INSTALLER"
        echo "Executando instalador do XAMPP (modo silencioso)..."
        if "$INSTALLER" --mode unattended; then
            echo "XAMPP instalado com sucesso em /opt/lampp."
        else
            echo "Aviso: Falha na execucao do instalador do XAMPP." >&2
            echo "Por favor, instale o XAMPP manualmente em /opt/lampp." >&2
        fi
        rm -f "$INSTALLER"
    else
        echo "Aviso: Nao foi possivel baixar o instalador do XAMPP automaticamente." >&2
        echo "O XAMPP Tray foi instalado, mas você precisará instalar o XAMPP manualmente." >&2
    fi
else
    echo "XAMPP ja esta instalado em /opt/lampp."
fi

# Install Python dependencies into the app directory
echo "Instalando dependencias Python..."
if ! pip3 install --quiet --target "$APP_DIR/lib" --break-system-packages pystray Pillow; then
    if ! pip3 install --quiet --target "$APP_DIR/lib" pystray Pillow; then
        echo "Aviso: Falha ao instalar dependencias Python via pip3." >&2
        echo "Tente instalar manualmente: pip3 install pystray Pillow" >&2
    fi
fi

# Update icon cache
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -f -t /usr/share/icons/hicolor >/dev/null 2>&1 || true
fi

# Refresh application menu so the launcher appears immediately
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
fi

# Grant passwordless sudo for XAMPP commands to the sudo group.
# Only the specific lampp binaries are whitelisted — nothing else.
cat > "$SUDOERS_FILE" <<'EOF'
# xampp-tray: allow sudo group members to run XAMPP commands without a password
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp start
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp stop
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp restart
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp status
%sudo ALL=(root) NOPASSWD: /opt/lampp/manager-linux-x64.run
%sudo ALL=(root) NOPASSWD: /opt/lampp/manager-linux.run
EOF

# sudoers files must be owned by root:root and not world-writable
chmod 0440 "$SUDOERS_FILE"
chown root:root "$SUDOERS_FILE"

# Validate syntax — if visudo rejects the file, remove it and abort
if ! visudo -c -f "$SUDOERS_FILE" >/dev/null 2>&1; then
    rm -f "$SUDOERS_FILE"
    echo "Aviso: nao foi possivel instalar regras sudoers. Os comandos XAMPP vao pedir senha." >&2
fi

echo "XAMPP Tray instalado com sucesso."
echo "Para iniciar: xampp-tray"
echo "O autostart esta configurado em /etc/xdg/autostart/xampp-tray.desktop"
echo "Log de instalacao disponivel em: $LOG_FILE"
echo "=== Instalacao concluida: $(date) ==="
