#!/bin/bash
set -e

SUDOERS_FILE="/etc/sudoers.d/xampp-tray"

# Warn if XAMPP is not installed — do NOT auto-install.
if [ ! -f "/opt/lampp/lampp" ]; then
    echo "Aviso: XAMPP nao encontrado em /opt/lampp." >&2
    echo "Instale o XAMPP manualmente antes de usar o xampp-tray." >&2
    echo "Download: https://www.apachefriends.org/download.html" >&2
fi

# Grant passwordless sudo for XAMPP commands to the sudo group.
cat > "$SUDOERS_FILE" <<'EOF'
# xampp-tray: allow sudo group members to run XAMPP commands without a password
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp start
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp stop
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp restart
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp status
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp startapache
%sudo ALL=(root) NOPASSWD: /opt/lampp/lampp startmysql
%sudo ALL=(root) NOPASSWD: /opt/lampp/manager-linux-x64.run
%sudo ALL=(root) NOPASSWD: /opt/lampp/manager-linux.run
EOF

chmod 0440 "$SUDOERS_FILE"
chown root:root "$SUDOERS_FILE"

if ! visudo -c -f "$SUDOERS_FILE" >/dev/null 2>&1; then
    rm -f "$SUDOERS_FILE"
    echo "Aviso: regras sudoers invalidas. Os comandos XAMPP vao pedir senha." >&2
fi

# Update desktop and icon caches
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -f -t /usr/share/icons/hicolor >/dev/null 2>&1 || true
fi
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
fi

echo "XAMPP Tray instalado com sucesso."
echo "Para iniciar: xampp-tray"
